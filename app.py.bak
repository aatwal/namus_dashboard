# ── Callbacks ─────────────────────────────────────────────────────────────────

@app.callback(
    Output("data-store", "data"),
    Output("upload-status", "children"),
    Output("county-filter", "options"),
    Input("upload", "contents"),
    State("upload", "filename"),
    prevent_initial_call=True,
)
def handle_upload(contents, filename):
    try:
        df = decode_upload(contents)
    except Exception as e:
        return no_update, f"Error: {e}", no_update

    counties = [{"label": c, "value": c} for c in sorted(df["County"].dropna().unique())]
    df["DLC"] = df["DLC"].dt.strftime("%Y-%m-%d")
    return df.to_json(orient="split"), f"{filename} · {len(df):,} cases", counties


@app.callback(
    Output("metric-cards", "children"),
    Output("age-bar", "figure"),
    Output("sex-pie", "figure"),
    Output("county-bar", "figure"),
    Output("race-pie", "figure"),
    Output("time-line", "figure"),
    Output("case-table", "data"),
    Input("data-store", "data"),
    Input("view-toggle", "value"),
    Input("county-filter", "value"),
    Input("search-box", "value"),
)
def update_all(stored, view, counties, search):
    empty_cards = dbc.Row([
        dbc.Col(metric_card("Total cases",     "—", BLUE,   "bi-people-fill"),  md=3),
        dbc.Col(metric_card("Children (< 18)", "—", RED,    "bi-person-fill"),  md=3),
        dbc.Col(metric_card("% children",      "—", PURPLE, "bi-percent"),      md=3),
        dbc.Col(metric_card("Top county",      "—", TEAL,   "bi-geo-alt-fill"), md=3),
    ], className="g-3").children

    if not stored:
        return empty_cards, EMPTY_FIG, EMPTY_FIG, EMPTY_FIG, EMPTY_FIG, EMPTY_FIG, []

    df = pd.read_json(stored, orient="split")
    df["DLC"] = pd.to_datetime(df["DLC"], errors="coerce")

    dff = df.copy()
    if view == "children":
        dff = dff[dff["Age"] < 18]
    if counties:
        dff = dff[dff["County"].isin(counties)]
    if search:
        s = search.lower()
        mask = (
            dff["Legal Last Name"].str.lower().str.contains(s, na=False) |
            dff["Legal First Name"].str.lower().str.contains(s, na=False) |
            dff["City"].str.lower().str.contains(s, na=False) |
            dff["County"].str.lower().str.contains(s, na=False)
        )
        dff = dff[mask]

    total   = len(dff)
    child_n = (dff["Age"] < 18).sum()
    pct     = f"{round(child_n / total * 100)}%" if total else "—"
    top_cty = dff["County"].value_counts().idxmax() if total else "—"

    cards = dbc.Row([
        dbc.Col(metric_card("Total cases",     f"{total:,}",   BLUE,   "bi-people-fill"),  md=3),
        dbc.Col(metric_card("Children (< 18)", f"{child_n:,}", RED,    "bi-person-fill"),  md=3),
        dbc.Col(metric_card("% children",      pct,            PURPLE, "bi-percent"),      md=3),
        dbc.Col(metric_card("Top county",      top_cty,        TEAL,   "bi-geo-alt-fill"), md=3),
    ], className="g-3").children

    # Age bar
    if view == "children":
        age_counts = dff["Child Group"].value_counts().reindex(["0–5", "6–12", "13–17"], fill_value=0)
        age_colors = AGE_COLORS
    else:
        age_counts = dff["Age Group"].value_counts().reindex(["Under 18", "18–29", "30–49", "50+"], fill_value=0)
        age_colors = GROUP_COLORS

    age_fig = go.Figure(go.Bar(
        x=age_counts.index.tolist(), y=age_counts.values.tolist(),
        marker_color=age_colors, marker_line_width=0,
    ))
    age_fig.update_layout(
        **CHART_LAYOUT,
        xaxis=dict(showgrid=False, showline=False),
        yaxis=dict(showgrid=True, gridcolor="#f1f5f9", zeroline=False),
    )

    # Sex donut
    sex_counts = dff["Biological Sex"].value_counts()
    sex_fig = go.Figure(go.Pie(
        labels=sex_counts.index.tolist(), values=sex_counts.values.tolist(),
        hole=0.55, marker_colors=SEX_COLORS,
        textinfo="label+percent", textfont_size=11,
    ))
    sex_fig.update_layout(**CHART_LAYOUT)

    # County bar (top 8, horizontal)
    cty_counts = dff["County"].value_counts().head(8).sort_values()
    cty_fig = go.Figure(go.Bar(
        y=cty_counts.index.tolist(), x=cty_counts.values.tolist(),
        orientation="h", marker_color=RED, marker_line_width=0,
    ))
    cty_fig.update_layout(
        **CHART_LAYOUT,
        xaxis=dict(showgrid=True, gridcolor="#f1f5f9", zeroline=False),
        yaxis=dict(showgrid=False),
    )

    # Race donut
    race_counts = dff["Race / Ethnicity"].value_counts().head(5)
    race_fig = go.Figure(go.Pie(
        labels=race_counts.index.tolist(), values=race_counts.values.tolist(),
        hole=0.55, marker_colors=RACE_COLORS,
        textinfo="label+percent", textfont_size=10,
    ))
    race_fig.update_layout(**CHART_LAYOUT)

    # Timeline
    dff2 = dff.dropna(subset=["DLC"])
    yearly = dff2.groupby(dff2["DLC"].dt.year).size().reset_index(name="count")
    yearly.columns = ["Year", "Count"]
    time_fig = go.Figure(go.Scatter(
        x=yearly["Year"], y=yearly["Count"],
        mode="lines+markers",
        line=dict(color=BLUE, width=2.5, shape="spline"),
        marker=dict(size=5, color=BLUE),
        fill="tozeroy", fillcolor="rgba(37,99,235,0.07)",
    ))
    time_fig.update_layout(
        **CHART_LAYOUT,
        xaxis=dict(showgrid=False, showline=False),
        yaxis=dict(showgrid=True, gridcolor="#f1f5f9", zeroline=False),
    )

    # Table
    table_df = dff[["Case Number", "Legal Last Name", "Legal First Name", "Missing Age",
                     "City", "County", "Biological Sex", "Race / Ethnicity", "DLC"]].copy()
    table_df["DLC"] = table_df["DLC"].dt.strftime("%Y-%m-%d")

    return cards, age_fig, sex_fig, cty_fig, race_fig, time_fig, table_df.to_dict("records")


if __name__ == "__main__":
    app.run(debug=False, port=8050)
