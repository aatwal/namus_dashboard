import base64
import io
import re
import pandas as pd
import plotly.graph_objects as go
from dash import Dash, html, dcc, dash_table, Input, Output, State, no_update
import dash_bootstrap_components as dbc

# ── Data loading ──────────────────────────────────────────────────────────────

def parse_df(raw: pd.DataFrame) -> pd.DataFrame:
    df = raw.copy()
    df.columns = df.columns.str.strip()

    def parse_age(s):
        m = re.search(r"(\d+)", str(s))
        return int(m.group(1)) if m else None

    def age_bucket(a):
        if a is None: return "Unknown"
        if a < 18:   return "Under 18"
        if a < 30:   return "18–29"
        if a < 50:   return "30–49"
        return "50+"

    def child_bucket(a):
        if a is None: return "Unknown"
        if a <= 5:   return "0–5"
        if a <= 12:  return "6–12"
        return "13–17"

    df["Age"] = df["Missing Age"].apply(parse_age)
    df["Age Group"] = df["Age"].apply(age_bucket)
    df["Child Group"] = df["Age"].apply(child_bucket)
    df["DLC"] = pd.to_datetime(df["DLC"], errors="coerce")
    return df


def decode_upload(contents: str) -> pd.DataFrame:
    _, content_string = contents.split(",", 1)
    decoded = base64.b64decode(content_string)
    raw = pd.read_csv(io.StringIO(decoded.decode("utf-8-sig")))
    return parse_df(raw)


# ── Design tokens ─────────────────────────────────────────────────────────────

NAVY   = "#1e3a5f"
BLUE   = "#2563eb"
RED    = "#dc2626"
PURPLE = "#7c3aed"
TEAL   = "#0d9488"
ORANGE = "#ea580c"
GRAY   = "#64748b"
PINK   = "#db2777"
GREEN  = "#16a34a"

AGE_COLORS   = [ORANGE, PURPLE, TEAL]
GROUP_COLORS = [RED, BLUE, GRAY, GREEN]
SEX_COLORS   = [BLUE, PINK]
RACE_COLORS  = [ORANGE, BLUE, GRAY, GREEN, PURPLE]

CHART_LAYOUT = dict(
    paper_bgcolor="rgba(0,0,0,0)",
    plot_bgcolor="rgba(0,0,0,0)",
    font=dict(family="Inter, system-ui, sans-serif", size=12, color="#64748b"),
    margin=dict(l=8, r=8, t=8, b=8),
    showlegend=False,
)

EMPTY_FIG = go.Figure()
EMPTY_FIG.update_layout(**CHART_LAYOUT)

# ── App ───────────────────────────────────────────────────────────────────────

app = Dash(
    __name__,
    external_stylesheets=[
        dbc.themes.BOOTSTRAP,
        "https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css",
    ],
    title="NamUs Dashboard",
)

# ── UI helpers ────────────────────────────────────────────────────────────────

def metric_card(label, value, color, icon):
    return dbc.Card(
        dbc.CardBody(
            html.Div([
                html.Div([
                    html.P(label, style={
                        "fontSize": "11px", "fontWeight": 600, "color": "#94a3b8",
                        "textTransform": "uppercase", "letterSpacing": "0.07em",
                        "marginBottom": "8px", "margin": 0,
                    }),
                    html.Div(str(value), style={
                        "fontWeight": 700, "color": "#0f172a",
                        "fontSize": "26px", "lineHeight": 1, "marginTop": "6px",
                    }),
                ]),
                html.Div(
                    html.I(className=f"bi {icon}", style={"fontSize": "20px", "color": color}),
                    style={
                        "width": "44px", "height": "44px", "borderRadius": "10px",
                        "backgroundColor": color + "22",
                        "display": "flex", "alignItems": "center",
                        "justifyContent": "center", "flexShrink": 0,
                    },
                ),
            ], style={"display": "flex", "justifyContent": "space-between", "alignItems": "center"}),
            style={"padding": "20px 22px"},
        ),
        style={
            "borderRadius": "12px", "border": "none",
            "borderLeft": f"4px solid {color}",
            "boxShadow": "0 1px 6px rgba(0,0,0,0.07)",
        },
    )


def chart_card(title, graph_id, height="230px"):
    return dbc.Card(
        dbc.CardBody([
            html.P(title, style={
                "fontSize": "11px", "fontWeight": 700, "color": "#94a3b8",
                "textTransform": "uppercase", "letterSpacing": "0.07em",
                "marginBottom": "10px",
            }),
            dcc.Graph(id=graph_id, config={"displayModeBar": False}, style={"height": height}),
        ], style={"padding": "18px 20px"}),
        style={
            "borderRadius": "12px", "border": "none",
            "boxShadow": "0 1px 6px rgba(0,0,0,0.07)", "height": "100%",
        },
    )


